      "width": 1,
      "description": "System clock input."
    },
    {
      "type": "reset",
      "direction": "input",
      "protocol": "generic",
      "port": "rst_ni",
      "width": 1,
      "description": "Active-low system reset input."
    },
    {
      "type": "bus",
      "direction": "slave",
      "protocol": "TL-UL",
      "port": "tl_i",
      "width": 1,
      "description": "TileLink UL register-access interface.",
      "signals": [
        {
          "name": "tl_i",
          "direction": "input",
          "type": "bus",
          "description": "TL-UL host-to-device (tl_h2d_t struct)"
        },
        {
          "name": "tl_o",
          "direction": "output",
          "type": "bus",
          "description": "TL-UL device-to-host (tl_d2h_t struct)"
        }
      ],
      "protocol_level": "baseline"
    },
    {
      "type": "serial",
      "direction": "output",
      "protocol": "SPI",
      "port": "spi_sclk_o",
      "width": 1,
      "description": "SPI clock output."
    },
    {
      "type": "serial",
      "direction": "output",
      "protocol": "SPI",
      "port": "spi_cs_no",
      "width": 1,
      "description": "SPI chip-select output (active low)."
    },
    {
      "type": "serial",
      "direction": "output",
      "protocol": "SPI",
      "port": "spi_mosi_o",
      "width": 1,
      "description": "SPI master-out slave-in data output."
    },
    {
      "type": "serial",
      "direction": "input",
      "protocol": "SPI",
      "port": "spi_miso_i",
      "width": 1,
      "description": "SPI master-in slave-out data input."
    },
    {
      "type": "interrupt",
      "direction": "output",
      "protocol": "generic",
      "port": "intr_tx_empty_o",
      "width": 1,
      "description": "Interrupt output for TX FIFO empty condition."
    },
    {
      "type": "interrupt",
      "direction": "output",
      "protocol": "generic",
      "port": "intr_rx_full_o",
      "width": 1,
      "description": "Interrupt output for RX FIFO full condition."
    },
    {
      "type": "interrupt",
      "direction": "output",
      "protocol": "generic",
      "port": "intr_idle_o",
      "width": 1,
      "description": "Interrupt output for SPI idle condition."
    }
  ],
  "parameters": [
    {
      "name": "FIFO_DEPTH",
      "type": "int",
      "default": 8,
      "description": "Configurable depth of TX and RX FIFOs (number of entries)."
    }
  ],
  "registers": [
    {
      "name": "CTRL",
      "offset": "0x00",
      "access": "RW",
      "description": "enable[0], cpol[1], cpha[2], xfer_len[7:3]"
    },
    {
      "name": "STATUS",
      "offset": "0x04",
      "access": "RO",
      "description": "busy[0], tx_full[1], tx_empty[2], rx_full[3], rx_empty[4]"
    },
    {
      "name": "DIV",
      "offset": "0x08",
      "access": "RW",
      "description": "SCLK divider [15:0]  (SCLK = clk / (2*(div+1)))"
    },
    {
      "name": "TXDATA",
      "offset": "0x0C",
      "access": "WO",
      "description": "TX FIFO push"
    },
    {
      "name": "RXDATA",
      "offset": "0x10",
      "access": "RO",
      "description": "RX FIFO pop"
    },
    {
      "name": "CSCTRL",
      "offset": "0x14",
      "access": "RW",
      "description": "cs_assert[0]  (1=assert, 0=deassert)"
    },
    {
      "name": "INTR_EN",
      "offset": "0x18",
      "access": "RW",
      "description": "Interrupt enable [2:0]"
    },
    {
      "name": "INTR_ST",
      "offset": "0x1C",
      "access": "RW",
      "description": "Interrupt status [2:0]  (W1C)"
    }
  ],
